---
import '@/styles/scss/card.scss';
import Base from '@/layouts/base.astro'
import Card from '@/components/card.astro'
import { projectData } from './data';
---

<Base title="Projetos" description="Alguns projetos meus" hero="/img/posts/The Combat of the Giaour and the Pasha.jpg">
  { projectData.length > 0 && (
    <div class="grid">
      {projectData.map((i) => (
        <a href={i.href} target="_blank">
          <Card name={i.name} desc={i.description} />
        </a>
      ))}
    </div>
  )}
</Base>




