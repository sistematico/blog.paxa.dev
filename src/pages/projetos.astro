---
import Base from "@/layouts/Base.astro";
import Card from "@/components/ProjectsCard.astro";
import projetos from "@/data/projetos.json";
---

<Base title="Projetos" description="Alguns projetos que criei">
  <h1 class="text-2xl font-extrabold text-skin-base">Projetos</h1>
  <div class="grid w-full grid-cols-1 gap-4 my-2 mt-4 sm:grid-cols-2">
    {
      projetos.map((projeto) => (
        <Card
          name={projeto.name}
          desc={projeto.desc}
          url={projeto.url}
          repo={projeto.repo}
        />
      ))
    }
  </div>
</Base>
