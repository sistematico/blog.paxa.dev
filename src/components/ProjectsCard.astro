---
const { name, desc, url, repo } = Astro.props;
---

<a
  href={url}
  class="border border-grey-200 dark:border-gray-800 rounded p-4 w-full bg-white dark:bg-gray-900"
>
  <h3 class="text-lg font-bold text-left text-gray-900 dark:text-gray-100">
    {name}
  </h3>
  <p class="mt-1 text-gray-700 dark:text-gray-400">{desc}</p>
</a>
