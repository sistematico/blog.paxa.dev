---
import Logo from '@/components/logo.astro';
import Nav from '@/components/nav.astro';
import Theme from '@/components/theme.astro';
const title = import.meta.env.PUBLIC_APP_NAME;
---

<header>
  <nav>
    <div class="logo">
      <a href="/">
        <Logo />
        <h2>{title}</h2>
      </a>
    </div>

    <div class="nav-links">
      <Nav href="/">Blog</Nav>
      <Nav href="/snippets">Snippets</Nav>
      <Nav href="/projetos">Projetos</Nav>
    </div>

    <div>
      <Theme />
    </div>
  </nav>
</header>

<style>
.logo a {
  display: flex;
  align-items: center;
  color: #fff;
  gap: 3px;
  border: none;
}

.logo a:hover { color: #fff; }

.logo a h2 {
  font-size: 1.5em;
  font-weight: 700;
}

header {
  position: sticky;
  top: 0;
  font-family: "Nunito", system-ui, "Segoe UI", sans-serif;
  background: rgba(var(--secondary-bg), .5);
  box-shadow: 0 2px 8px rgba(var(--black), 5%);
  border-bottom: 2px solid rgba(var(--secondary-bg), .9);
  backdrop-filter: blur(10px);
  z-index: 9999;
}

nav {
  display: flex;
  align-items: center;
  /* justify-content: space-between; */
  /* margin: 0 1em; */
}

nav div {
  flex: 1;
  display: flex;
  justify-content: center;
}

/* nav:first-child > span { margin-right: auto; } */
/* nav:last-child  > span { margin-left: auto;  } */

@media (max-width: 720px) {
  header { 
    padding: 0 .2em; 
  }
  
  .logo a h2 { 
    display: none; 
  }
  
  nav, nav div { 
    flex-direction: column;
    margin: 0 .5em; 
  }
 
  /* nav a { 
    padding: .4em 0.25em; 
  } */
}
</style>

<script is:inline>
function myFunction() {
  const nav = document.getElementById("myTopnav");
  const burger = document.querySelector(".burger");
  
  if (nav.className === "topnav") {
    nav.className += " responsive";
    burger.innerHTML = "X";
  } else {
    nav.className = "topnav";
    burger.innerHTML = "Menu";
  }
}


