				color: rgb(var(--gray));
			}
			
			.last-updated-on {
				font-style: italic;
			}
		</style> -->
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={created} />
							{
								updated && (
									<div class="last-updated-on">
										Atualizado em <FormattedDate date={updated} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>