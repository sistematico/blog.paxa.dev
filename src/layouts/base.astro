---
import '@/styles/scss/main.scss';
import Head from '@/layouts/head.astro';
import Header from '@/components/header.astro';
import Footer from '@/components/footer.astro';
const { title = 'Paxá Blog', description = 'Dicas e tutoriais sobre desenvolvimento web', hero } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} />
  </head>
  <body>
    <div class="container">    
      <Header />
      <main>
        <article>
          {hero && 
            <div class="hero-image">
              <img width={1020} height={510} src={hero} alt={title} />
            </div>
          }
          <slot />
        </article>
      </main>
      <Footer />
    </div>
  </body>
</html>