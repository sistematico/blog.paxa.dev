{
  "$schema": "https://biomejs.dev/schemas/1.8.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 320
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded",
      "trailingCommas": "none",
      "quoteStyle": "single",
      "lineWidth": 320
    }
  },
  "files": {
    "ignore": [
      "settings.json",
      "node_modules",
      "dist",
      "build",
      "coverage",
      ".nyc_output",
      ".cache",
      ".vscode",
      ".idea",
      ".DS_Store",
      ".env",
      ".env.local",
      ".env.development.local",
      ".env.test.local",
      ".env.production.local",
      "yarn.lock",
      "package-lock.json",
      "npm-debug.log",
      "yarn-debug.log",
      "yarn-error.log",
      "pnpm-debug.log",
      "pnpm-lock.yaml",
      "tsconfig.tsbuildinfo",
      "tsconfig.json",
      "tsconfig.build.json",
      "tsconfig.eslint.json",
      "tsconfig.jest.json",
      "jest.config.js",
      "jest.setup.js",
      "jest.config.ts",
      "jest.setup.ts",
      "jest.config.cjs",
      "jest.setup.cjs",
      "jest.config.mjs",
      "jest.setup.mjs",
      "babel.config.js",
      "babel.config.ts",
      "babel.config.cjs",
      "babel.config.mjs",
      "webpack.config.js",
      "webpack.config.ts",
      "webpack.config.cjs",
      "webpack.config.mjs",
      "rollup.config.js",
      "rollup.config.ts",
      "rollup.config.cjs",
      "rollup.config.mjs",
      "gulpfile.js",
      "gulpfile.ts",
      "gulpfile.cjs",
      "gulpfile.mjs",
      "Gruntfile.js",
      "Gruntfile.ts",
      "Gruntfile.cjs",
      "Gruntfile.mjs",
      "karma.conf.js",
      "protractor.conf.js",
      "nightwatch.conf.js",
      "wdio.conf.js",
      "tslint.json",
      ".eslintrc",
      ".eslintrc.js",
      ".eslintrc.json",
      ".eslintrc.yaml",
      ".eslintrc.yml",
      ".eslintrc.cjs",
      ".eslintrc.mjs",
      ".eslintignore",
      ".prettierrc",
      ".prettierrc.js",
      ".prettierrc.json",
      ".prettierrc.yaml",
      ".prettierrc.yml",
      ".prettierrc.cjs",
      ".prettierrc.mjs",
      ".prettierignore",
      ".stylelintrc",
      ".stylelintrc.js",
      ".stylelintrc.json",
      ".stylelintrc.yaml",
      ".stylelintrc.yml",
      ".stylelintrc.cjs",
      ".stylelintrc.mjs",
      ".stylelintignore",
      ".huskyrc",
      ".huskyrc.js",
      ".huskyrc.json",
      ".hus"
    ]
  }
}
